import java.util.Scanner;

public class ATM {

    private Bank bank;
    private Account currentAccount;
    private Scanner scanner;

    // Constructor
    public ATM(Bank bank) {
        this.bank = bank;
        scanner = new Scanner(System.in);
    }

// Start ATM
public void start() {

    int choice;

    do {

        System.out.println("\n====================================");
        System.out.println("          WELCOME TO ATM SYSTEM");
        System.out.println("====================================");

        System.out.println("1. Login");
        System.out.println("2. Create Account");
        System.out.println("3. Exit");

        System.out.print("Enter your choice: ");

        choice = scanner.nextInt();


        switch(choice) {


            case 1:

                login();

                if(currentAccount != null) {
                    showMenu();
                }

                break;


            case 2:

                createAccount();

                break;


            case 3:

                System.out.println("\nThank you for using ATM.");
                System.out.println("Goodbye!");

                break;


            default:

                System.out.println("Invalid Choice.");

        }


    }while(choice != 3);

}

    // Login Method
    private void login() {

        int attempts = 3;

        while (attempts > 0) {

            System.out.print("Enter User ID: ");
            int userId = scanner.nextInt();

            System.out.print("Enter PIN: ");
            int pin = scanner.nextInt();

            currentAccount = bank.authenticate(userId, pin);

            if (currentAccount != null) {
                System.out.println("\nLogin Successful!");
                System.out.println("Welcome " + currentAccount.getAccountHolderName());
                return;
            }

            attempts--;

            if (attempts > 0) {
                System.out.println("Invalid User ID or PIN.");
                System.out.println("Attempts Remaining: " + attempts);
            }
        }

        System.out.println("\nToo many incorrect attempts.");
        System.out.println("ATM Locked.");
    }

    // Main Menu
    private void showMenu() {

        int choice;

        do {

            System.out.println("\n========== ATM MENU ==========");
            System.out.println("1. Transaction History");
            System.out.println("2. Withdraw");
            System.out.println("3. Deposit");
            System.out.println("4. Transfer");
            System.out.println("5. Balance Inquiry");
            System.out.println("6. Quit");
            System.out.print("Enter your choice: ");

            choice = scanner.nextInt();

            switch (choice) {

                case 1:
                    currentAccount.displayTransactionHistory();
                    break;

                case 2:
                    withdraw();
                    break;

                case 3:
                    deposit();
                    break;

                case 4:
                    transfer();
                    break;

                case 5:
                    System.out.println("Current Balance: ₹" + currentAccount.getBalance());
                    break;

                case 6:
                    System.out.println("\nThank you for using our ATM.");
                    System.out.println("Goodbye!");
                    break;

                default:
                    System.out.println("Invalid Choice.");
            }

        } while (choice != 6);
    }

    //create account method
    private void createAccount() {
        System.out.print("Enter User ID: ");
        int userId = scanner.nextInt();

        System.out.print("Enter Account Holder Name: ");
        String name = scanner.next();
    System.out.print("Enter PIN: ");
    int pin;

    while(true){

    if(scanner.hasNextInt()){

        pin=scanner.nextInt();
        break;

    }
    else{

        System.out.println("Please enter numbers only.");
        scanner.next();

    }

}

        System.out.print("Enter Initial Balance: ₹");
        double initialBalance = scanner.nextDouble();

        Account newAccount = new Account(userId, name, pin, initialBalance);
        bank.addAccount(newAccount);

        System.out.println("Account created successfully!");
    }

    // Deposit
    private void deposit() {

        System.out.print("Enter amount to deposit: ₹");
        double amount = scanner.nextDouble();

        currentAccount.deposit(amount);
    }

    // Withdraw
    private void withdraw() {

        System.out.print("Enter amount to withdraw: ₹");
        double amount = scanner.nextDouble();

        currentAccount.withdraw(amount);
    }

    // Transfer
    private void transfer() {

        System.out.print("Enter Receiver User ID: ");
        int receiverId = scanner.nextInt();

        Account receiver = bank.findAccount(receiverId);

        if (receiver == null) {
            System.out.println("Receiver account not found.");
            return;
        }

        if (receiver.getUserId() == currentAccount.getUserId()) {
            System.out.println("Cannot transfer to your own account.");
            return;
        }

        System.out.print("Enter amount to transfer: ₹");
        double amount = scanner.nextDouble();

        currentAccount.transfer(receiver, amount);
    }

    private void checkBalance() {
        double balance = currentAccount.getBalance();
        System.out.println("Current Balance: ₹" + balance);
    }
}
//Transection.java
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;

public class Transaction {

    private String transactionType;
    private double amount;
    private String description;
    private String dateTime;

    // Constructor
    public Transaction(String transactionType, double amount, String description) {
        this.transactionType = transactionType;
        this.amount = amount;
        this.description = description;

        DateTimeFormatter formatter =
                DateTimeFormatter.ofPattern("dd-MM-yyyy HH:mm:ss");
        this.dateTime = LocalDateTime.now().format(formatter);
    }

    // Getters
    public String getTransactionType() {
        return transactionType;
    }

    public double getAmount() {
        return amount;
    }

    public String getDescription() {
        return description;
    }

    public String getDateTime() {
        return dateTime;
    }

    // Display Transaction
    @Override
    public String toString() {
    return "----------------------------------\n" +
           "Transaction Type : " + transactionType + "\n" +
           "Amount           : ₹" + amount + "\n" +
           "Description      : " + description + "\n" +
           "Date & Time      : " + dateTime + "\n" +
           "----------------------------------";
  }
}
//Account.java
import java.util.ArrayList;

public class Account {

    // Data Members
    private int userId;
    private String accountHolderName;
    private int pin;
    private double balance;
    private ArrayList<Transaction> transactionHistory = new ArrayList<>();

    // Constructor
    public Account(int userId, String accountHolderName, int pin, double balance) {
        this.userId = userId;
        this.accountHolderName = accountHolderName;
        this.pin = pin;
        this.balance = balance;
    }

    // Getters
    public int getUserId() {
        return userId;
    }

    public String getAccountHolderName() {
        return accountHolderName;
    }

    public int getPin() {
        return pin;
    }
    public double getBalance() {
        return balance;
    }

    public boolean checkPin(int enteredPin) {
        return this.pin == enteredPin;
    }
    public void deposit(double amount) {
        if (amount > 0) {
            balance += amount;
            Transaction transaction = new Transaction("Deposit", amount, "Deposited to account");
            addTransaction(transaction);
        } else {
            System.out.println("Invalid deposit amount.");
        }
    }

    public boolean withdraw(double amount) {
        if (amount > 0 && amount <= balance) {
            balance -= amount;
            Transaction transaction = new Transaction("Withdrawal", amount, "Withdrawn from account");
            addTransaction(transaction);
            return true;
        } else {
            if (amount <= 0) {
                System.out.println("Invalid amount.");
            } else if (amount > balance) {
                System.out.println("Insufficient Funds.");
            }
            return false;
        }
    }

    public boolean transfer(Account receiver, double amount) {
        if (amount > 0 && amount <= balance) {
            balance -= amount;
            receiver.deposit(amount);
            Transaction transaction = new Transaction("Transfer", amount, "Transferred to account ID: " + receiver.getUserId());
            addTransaction(transaction);
            return true;
        } else {
            System.out.println("Invalid transfer amount or insufficient balance.");
            return false;
        }
    }

    public void addTransaction(Transaction transaction) {
        transactionHistory.add(transaction);
    }

    public void displayTransactionHistory() {
        if (transactionHistory.isEmpty()) {
            System.out.println("No transactions found.");
        } else {
            System.out.println("Transaction History for Account ID: " + userId);
            for (Transaction transaction : transactionHistory) {
                System.out.println(transaction);
            }
        }
    }

}
//Bank.java
import java.util.ArrayList;

public class Bank {

    private ArrayList<Account> accounts;

    public Bank() {
        accounts = new ArrayList<>();
    }

    public void addAccount(Account account) {
        accounts.add(account);
    }

    public Account findAccount(int userId) {
        for (Account account : accounts) {
            if (account.getUserId() == userId) {
                return account;
            }
        }
        return null;
    }

    public Account authenticate(int userId, int pin) {
        Account account = findAccount(userId);

        if (account != null && account.checkPin(pin)) {
            return account;
        }

        return null;
    }
}
